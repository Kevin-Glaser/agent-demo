OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1

LLM_MODEL=deepseek-chat
TEMPERATURE=0.7
MAX_RETRIES=3

MCP_CONFIG_PATH=mcp.json

SKILLS_DIRECTORY=storage/skills
SKILLS_EXTRA_DIRS=
SKILLS_MAX_IN_PROMPT=50
SKILLS_MAX_PROMPT_CHARS=8000

CONVERSATION_MAX_TOKENS=128000
CONVERSATION_RESERVED_TOKENS=20000
CONVERSATION_PRUNE_PROTECT=40000
CONVERSATION_AUTO_COMPACT=true

# Reasoning model detection
# Comma-separated list of model names that support reasoning (e.g., "deepseek-r1,o1,o3,o4")
REASONING_MODELS=
# Fallback string patterns to detect reasoning models (used if REASONING_MODELS is not set)
REASONING_MODEL_PATTERNS=r1,o1,o3
